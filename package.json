{
  "name": "@flippydisk/tools",
  "version": "1.1.0",
  "description": "A set of JS utilities to help with web development",
  "homepage": "https://www.flipppydisk.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/flippydisk/tools.git"
  },
  "author": "Jim O'Harra-Sutton (https://www.flippydisk.com)",
  "type": "module",
  "main": "./dist/cjs/index.cjs",
  "module": "./dist/esm/index.js",
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.cjs"
    },
    "./debug": {
      "import": "./dist/esm/debug/debug.js",
      "require": "./dist/cjs/debug/debug.cjs"
    },
    "./disable": {
      "import": "./dist/esm/disable/disable.js",
      "require": "./dist/cjs/disable/disable.cjs"
    },
    "./json": {
      "import": "./dist/esm/json/json.js",
      "require": "./dist/cjs/json/json.cjs"
    },
    "./json/ajax": {
      "import": "./dist/esm/json/ajax.js",
      "require": "./dist/cjs/json/ajax.cjs"
    },
    "./json/promise": {
      "import": "./dist/esm/json/promise.js",
      "require": "./dist/cjs/json/promise.cjs"
    },
    "./json/responder": {
      "import": "./dist/esm/json/responder.js",
      "require": "./dist/cjs/json/responder.cjs"
    },
    "./lang": {
      "import": "./dist/esm/lang/lang.js",
      "require": "./dist/cjs/lang/lang.cjs"
    },
    "./tests": {
      "import": "./dist/esm/tests/tests.js",
      "require": "./dist/cjs/tests/tests.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "docs",
    "dist",
    "src"
  ],
  "keywords": [
    "flippydisk",
    "tools",
    "web tools",
    "debug",
    "debugger",
    "debugging",
    "log",
    "logger",
    "logging",
    "console"
  ],
  "dependencies": {
    "jsdom": "^16.7.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@swc/core": "^1.13.5",
    "@swc/jest": "^0.2.39",
    "cross-env": "^10.1.0",
    "documentjs": "^0.5.5",
    "eslint": "^9.39.1",
    "globals": "^16.4.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jest-fetch-mock": "^3.0.3",
    "jest-raw-loader": "^1.0.1"
  },
  "scripts": {
    "lint": "cross-env eslint ./src --fix",
    "test": "npm run lint && jest --coverage --verbose",
    "test:watch": "npm run lint && jest --watch --coverage --verbose",
    "build": "npm run test && node ./scripts/build.js",
    "build:production": "npm run test && npm run docs && node ./scripts/build.js",
    "docs": "cross-env documentjs",
    "docs:watch": "cross-env documentjs --watch",
    "update": "cross-env ./scripts/update.sh",
    "release": "cross-env ./scripts/npm-release.sh",
    "bump": "cross-env ./scripts/bump.sh"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/flippydisk/tools/issues"
  },
  "directories": {
    "doc": "docs",
    "lib": "dist"
  },
  "engines": {
    "node": ">=18"
  },
  "sideEffects": false
}
